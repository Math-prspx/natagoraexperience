# ==========================
# Natagora API configuration
# ==========================
# Copy this file to .env (git ignored) and adjust values per environment.

# App
APP_BASE_URL=/api
APP_DEFAULT_LOCALE=fr
DEBUG_MODE=0

# Database
DB_DRIVER=sqlite
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=natagora_catalogue
DB_USER=db_user
DB_PASS=db_password
DB_CHARSET=utf8mb4
DB_SQLITE_PATH=database/local.sqlite

# Admin auth
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=REPLACE_WITH_BCRYPT_HASH
ADMIN_AUTH_SECRET=REPLACE_WITH_RANDOM_64_HEX_SECRET
ADMIN_TOKEN_TTL=28800
